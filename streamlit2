from sklearn.cluster import KMeans
from sklearn.metrics import silhouette_score
from dash import Dash, html, dcc, Input, Output
import dash_bootstrap_components as dbc

# Function to load data from CSV or Excel files
def load_data(file_path):
    if file_path.endswith('.csv'):
        data = pd.read_csv(file_path)
    elif file_path.endswith('.xlsx'):
        data = pd.read_excel(file_path)
    else:
        raise ValueError("Unsupported file format. Please provide a CSV or Excel file.")
    return data

# Function to validate the loaded data
def validate_data(data):
    if data.empty:
        raise ValueError("The dataset is empty.")
    if data.shape[1] < 2:
        raise ValueError("The dataset should have at least one feature and one label column.")
    return data.iloc[:, :-1], data.iloc[:, -1]  # return features and labels separately

# Function to plot 2D visualizations using PCA and t-SNE
def plot_2d_visualizations(X, y):
    pca = PCA(n_components=2)
    X_pca = pca.fit_transform(X)
    tsne = TSNE(n_components=2, random_state=42)
    X_tsne = tsne.fit_transform(X)

    plt.figure(figsize=(14, 6))
    plt.subplot(1, 2, 1)
    plt.scatter(X_pca[:, 0], X_pca[:, 1], c=y)
    plt.title('PCA Visualization')
    plt.colorbar()

    plt.subplot(1, 2, 2)
    plt.scatter(X_tsne[:, 0], X_tsne[:, 1], c=y)
    plt.title('t-SNE Visualization')
    plt.colorbar()
    plt.show()

# Load and validate data
file_path = 'your_data_file.csv'  # Change this to your file path
data = load_data(file_path)
X, y = validate_data(data)

