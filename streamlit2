@app.callback(
    Output('2d-graph', 'figure'),
    Input('plot-2d', 'n_clicks')
)
def display_2d_visualizations(n_clicks):
    if n_clicks > 0:
        pca = PCA(n_components=2)
        X_pca = pca.fit_transform(X)
        tsne = TSNE(n_components=2, random_state=42)
        X_tsne = tsne.fit_transform(X)

        fig = plt.figure(figsize=(14, 6))
        ax1 = fig.add_subplot(121)
        scatter = ax1.scatter(X_pca[:, 0], X_pca[:, 1], c=y, cmap='viridis')
        ax1.set_title('PCA Visualization')
        fig.colorbar(scatter, ax=ax1)

        ax2 = fig.add_subplot(122)
        scatter = ax2.scatter(X_tsne[:, 0], X_tsne[:, 1], c=y, cmap='viridis')
        ax2.set_title('t-SNE Visualization')
        fig.colorbar(scatter, ax=ax2)

        return fig
    return {}

@app.callback(
    Output('knn-output', 'children'),
    Input('run-knn', 'n_clicks'),
    Input('k-input', 'value')
)
def run_knn(n_clicks, k):
    if n_clicks > 0:
        X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)
        knn = KNeighborsClassifier(n_neighbors=k)
        knn.fit(X_train, y_train)
        y_pred = knn.predict(X_test)
        acc = accuracy_score(y_test, y_pred)
        cm = confusion_matrix(y_test, y_pred)
        return f"Accuracy: {acc}, Confusion Matrix: {cm}"
    return ""

@app.callback(
    Output('kmeans-output', 'children'),
    Input('run-kmeans', 'n_clicks'),
    Input('k-cluster-input', 'value')
)
def run_kmeans(n_clicks, k):
    if n_clicks > 0:
        kmeans = KMeans(n_clusters=k, random_state=42)
        y_kmeans = kmeans.fit_predict(X)
        sil_score = silhouette_score(X, y_kmeans)
        return f"Silhouette Score: {sil_score}"
    return ""

if __name__ == '__main__':
    app.run_server(debug=True)
